# Supabase — boş qalanda tətbiq nümunə (mock) data ilə işləyir.
# Dəyərlər: Supabase Dashboard → Project Settings → API Keys / Data API
#   URL  → "Project URL"  (https://<layihə-id>.supabase.co)
#   KEY  → "anon" / "publishable" açar (service_role AÇARINI BURA YAZMAYIN!)
# Lokal üçün bu faylı .env.local adı ilə kopyalayıb doldurun.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web Push (VAPID) — açarları yaratmaq üçün: npx web-push generate-vapid-keys
# Açıq açar brauzerə gedir; GİZLİ açar yalnız serverdə qalır (NEXT_PUBLIC_ YOX!).
# Boş qalanda bildiriş funksiyası sadəcə gizlədilir — tətbiq işləməyə davam edir.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Saytın tam ünvanı — QR posterlər, sitemap, canonical linklər üçün
# (məs. https://xidirli.vercel.app — SEO üçün mütləq doldurun!)
NEXT_PUBLIC_SITE_URL=

# Google Search Console təsdiqi (istəyə bağlı) — Search Console → Settings →
# Ownership verification → HTML tag üsulundakı content="..." dəyərini bura yazın
GOOGLE_SITE_VERIFICATION=

# Anım günü bildirişləri (Vercel Cron) üçün:
# CRON_SECRET — istənilən uzun təsadüfi sətir (Vercel sorğuya özü qoşur)
# SUPABASE_SERVICE_ROLE_KEY — Dashboard → API Keys → "secret" açar.
# DİQQƏT: bu açar YALNIZ cron marşrutunda işlədilir, əsla NEXT_PUBLIC_ olmasın!
CRON_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini TTS (istəyə bağlı) — "Səsli dinlə" audio fayllarını yaratmaq üçün,
# yalnız scripts/tts.mjs skriptində işlədilir (sayt işləyəndə lazım deyil).
# Açar: aistudio.google.com → "Get API key" (Google hesabı yetər, kart istəmir).
GEMINI_API_KEY=
# İstəyə bağlı: model/səs seçimi (defaultlar: gemini-3.1-flash-tts-preview / Sulafat)
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Kore
