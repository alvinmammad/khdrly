# Supabase — boş qalanda tətbiq nümunə (mock) data ilə işləyir.
# Dəyərlər: Supabase Dashboard → Project Settings → API Keys / Data API
#   URL  → "Project URL"  (https://<layihə-id>.supabase.co)
#   KEY  → "anon" / "publishable" açar (service_role AÇARINI BURA YAZMAYIN!)
# Lokal üçün bu faylı .env.local adı ilə kopyalayıb doldurun.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Web Push (VAPID) — açarları yaratmaq üçün: npx web-push generate-vapid-keys
# Açıq açar brauzerə gedir; GİZLİ açar yalnız serverdə qalır (NEXT_PUBLIC_ YOX!).
# Boş qalanda bildiriş funksiyası sadəcə gizlədilir — tətbiq işləməyə davam edir.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Saytın tam ünvanı — QR posterlərdəki linklər üçün (məs. https://xidirli.vercel.app)
NEXT_PUBLIC_SITE_URL=

# Azure TTS (istəyə bağlı) — "Səsli dinlə" audio fayllarını yaratmaq üçün,
# yalnız scripts/tts.mjs skriptində istifadə olunur (sayt işləyəndə lazım deyil).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
